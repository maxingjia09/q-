<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <rect width="1200" height="800" fill="#7cc7e3"/>
  <!-- 雪山顶部 -->
  <path d="M600 100 L300 400 L400 400 L200 500 L300 500 L100 600 L300 600 L400 700 L0 700 L0 800 L1200 800 L1200 700 L800 700 L900 600 L1100 600 L900 500 L1000 500 L800 400 L900 400 Z" fill="#ffffff" opacity="0.9"/>
  <!-- 雪山阴影 -->
  <path d="M600 100 L300 400 L200 500 L100 600 L0 700 L0 800 L400 800 L400 700 L300 600 L300 500 L400 400 Z" fill="#e6f2ff" opacity="0.7"/>
  <!-- 褐色山体 -->
  <path d="M400 700 L0 700 L0 800 L1200 800 L1200 700 L800 700 L900 600 L1100 600 L1000 550 L900 500 L900 480 L1000 450 L900 400 L1000 350 L800 300 L700 200 Z" fill="#8b6914" opacity="0.8"/>
  <!-- 云层 -->
  <ellipse cx="400" cy="150" rx="150" ry="50" fill="#ffffff" opacity="0.8"/>
  <!-- 调整暗色区域 -->
  <path d="M600 100 L500 250 L400 350 L350 400 L300 420 L250 450 L200 480 L150 520 L100 560 L50 620 L0 700 L0 800 L400 800 L400 700 L350 650 L300 620 L300 580 L350 550 L400 520 L450 480 L500 440 L550 400 L600 360 L650 320 L700 280 L750 240 L800 200 L850 160 L900 120 L850 100 L800 110 L750 130 L700 160 Z" fill="#333333" opacity="0.1"/>
</svg>